# Deploy environment settings
# Copy this file to deploy.env and fill in your values:
#   cp deploy/deploy.env.example deploy/deploy.env

# Dev account
DEV_REGISTRY="<account>.registry.snowflakecomputing.com/<db>/<schema>/<repo>/<image-name>"
DEV_CONNECTION_FLAG=""                    # empty = default snow connection

# Production account
PROD_REGISTRY="<account>.registry.snowflakecomputing.com/<db>/<schema>/<repo>/<image-name>"
PROD_CONNECTION_FLAG="-c <connection>"    # snow CLI connection name

# Application package stage
STAGE="@<APP_PKG>.APP_SRC.STAGE"
